{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "aivv-commerce",
  "version": "0.1.3",
  "identifier": "com.aivv.commerce",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000/login?platform=desktop",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Aivv Console",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "https://aivv.app/login?platform=desktop"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
